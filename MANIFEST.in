include README.md
include CONTRIBUTING.md
include LICENSE
include SECURITY.md
include CHANGELOG.md
include .env.example
recursive-include src/crupier *.py py.typed
recursive-include examples *.json *.py
prune .crupier
prune .venv
prune dist
prune build
prune tests
global-exclude __pycache__/*
global-exclude *.py[cod]
global-exclude .DS_Store
